# ==================== UTILISATEUR ====================
USER_NAME=
USER_EMAIL=

# ==================== DOSSIERS ====================
# Exemple:
# WATCH_FOLDER=C:\Users\me\Documents\Meetings\input
# OUTPUT_FOLDER=C:\Users\me\Documents\Meetings\output
WATCH_FOLDER=
OUTPUT_FOLDER=

# ==================== API ACTIVE (true/false) ====================
USE_GEMINI=false
USE_CLAUDE=true
USE_OPENAI=false
USE_PERPLEXITY=false

# ==================== API KEYS ====================
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ==================== MODELES ====================
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# ==================== EMAIL (optionnel / legacy) ====================
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_MODE=starttls
SMTP_USER=

# ==================== NOTIFICATIONS ====================
# Debug uniquement. Laisser à false par défaut.
NOTIFY_FORCE_POPUP=false

